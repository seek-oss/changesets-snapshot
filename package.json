    "changeset": "changeset",
    "format": "skuba format",
    "lint": "skuba lint",
    "release": "node ./scripts/release.ts",
    "test": "vitest --run",
    "test:ci": "vitest --run --coverage",
    "test:watch": "skuba test --watch"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
